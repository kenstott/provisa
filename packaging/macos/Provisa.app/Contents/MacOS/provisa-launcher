#!/usr/bin/env bash
# Phase AF2a — Provisa.app launcher.
# Handles first-launch setup then delegates to the provisa CLI.
set -euo pipefail

CONTENTS="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MACOS_DIR="${CONTENTS}/MacOS"
FIRST_LAUNCH_SCRIPT="${MACOS_DIR}/first-launch.sh"
PROVISA_CLI="${CONTENTS}/Resources/provisa-cli"
SENTINEL="${HOME}/.provisa/.first-launch-complete"

ARCH="$(uname -m)"
case "$ARCH" in
  arm64)  BIN_ARCH="arm64" ;;
  x86_64) BIN_ARCH="x86_64" ;;
  *)
    printf "[provisa] Unsupported architecture: %s\n" "$ARCH" >&2
    exit 1
    ;;
esac

export PATH="${MACOS_DIR}/bin/${BIN_ARCH}:${PATH}"

# ── First launch ──────────────────────────────────────────────────────────────
if [ ! -f "$SENTINEL" ]; then
  if [ ! -x "$FIRST_LAUNCH_SCRIPT" ]; then
    osascript -e 'display alert "Provisa" message "Setup script not found. Please reinstall Provisa." as critical'
    exit 1
  fi

  # The app has no terminal (LSUIElement). Open a Terminal window so the
  # user can see progress, answer prompts, and watch setup complete.
  # The wrapper self-deletes after exec so the temp file isn't left around.
  WRAP="$(mktemp "${TMPDIR:-/tmp}/provisa-setup-XXXXX.sh")"
  printf '#!/usr/bin/env bash\nrm -f "%s"\nexec "%s"\n' "$WRAP" "$FIRST_LAUNCH_SCRIPT" > "$WRAP"
  chmod +x "$WRAP"
  osascript \
    -e 'tell application "Terminal"' \
    -e "  do script \"$WRAP\"" \
    -e '  activate' \
    -e 'end tell'
  exit 0
fi

# ── Delegate to provisa CLI ───────────────────────────────────────────────────
if [ -x "/usr/local/bin/provisa" ]; then
  exec /usr/local/bin/provisa "$@"
elif [ -x "$PROVISA_CLI" ]; then
  exec "$PROVISA_CLI" "$@"
else
  osascript -e 'display alert "Provisa" message "Setup is not complete. Please open Provisa.app to run first-launch setup." as warning'
  exit 1
fi
