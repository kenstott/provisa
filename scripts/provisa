#!/usr/bin/env bash
# Provisa CLI wrapper. Native tier (runtime: native): runs uvicorn against the
# ~/.provisa/venv Python. Docker tier: `docker compose` on the user's own Docker
# (Docker Desktop / colima) — no VM. image_source: tarball adds the airgap overlay
# so build: services resolve to the loaded provisa/*:local image tags.
set -euo pipefail

if [ -f "${HOME}/.provisa_home" ]; then
    PROVISA_HOME="$(cat "${HOME}/.provisa_home")"
else
    PROVISA_HOME="${HOME}/.provisa"
fi
CONFIG_FILE="${PROVISA_HOME}/config.yaml"
LOG_DIR="${PROVISA_HOME}/.logs"

# ── Colors ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'
BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

info()  { printf "${CYAN}[provisa]${NC} %s\n" "$*"; }
ok()    { printf "${GREEN}[provisa]${NC} %s\n" "$*"; }
warn()  { printf "${YELLOW}[provisa]${NC} %s\n" "$*"; }
err()   { printf "${RED}[provisa]${NC} %s\n" "$*" >&2; }

# ── Config reader (pure bash, no yaml parser needed) ────────────────────────
read_config() {
    local key="$1"
    local default="${2:-}"
    if [ -f "$CONFIG_FILE" ]; then
        local val
        val="$(grep "^${key}:" "$CONFIG_FILE" 2>/dev/null | head -1 | sed 's/^[^:]*: *//' | sed 's/^"//' | sed 's/"$//' | sed "s/^'//" | sed "s/'$//")"
        if [ -n "$val" ]; then
            echo "$val"
            return
        fi
    fi
    echo "$default"
}

PROJECT_DIR="$(read_config project_dir "")"
UI_PORT="$(read_config ui_port 3000)"
API_PORT="$(read_config api_port 8000)"
FLIGHT_PORT="$(read_config flight_port 8815)"
AUTO_OPEN="$(read_config auto_open_browser true)"
FED_WORKERS="$(read_config federation_workers 0)"
RUNTIME="$(read_config runtime docker)"
# image_source: build (host `docker compose build`) or tarball (docker load — add the
# airgap overlay so build: services resolve to the loaded provisa/*:local tags).
IMAGE_SOURCE="$(read_config image_source build)"

# ── Deployment fields (REQ-972..979) ────────────────────────────────────────
# The native tier runs the bundled Python runtime directly (no Docker). These
# select the federation engine / external stores / obs export at start.
DEPLOY_ENGINE="$(read_config engine duckdb)"
ENGINE_URL="$(read_config engine_url "")"
MATERIALIZE_URL="$(read_config materialize_url "")"
TRINO_HOST="$(read_config trino_host "")"
TRINO_PORT="$(read_config trino_port "")"
OBS_MODE="$(read_config obs_mode none)"
OTLP_ENDPOINT="$(read_config otlp_endpoint "")"
DEMO="$(read_config demo false)"

RUNTIME_DIR="${PROVISA_HOME}/venv"          # Python venv (native tier)
NATIVE_PID_FILE="${PROVISA_HOME}/.native.pid"

# ── Validation ──────────────────────────────────────────────────────────────
# The native tier has no compose project; only the Docker tiers need project_dir.
if [ "$RUNTIME" != "native" ]; then
    if [ -z "$PROJECT_DIR" ] || [ ! -d "$PROJECT_DIR" ]; then
        printf "${RED}[provisa]${NC} Project directory not configured or missing.\n" >&2
        printf "Run install.sh from the Provisa source directory.\n" >&2
        exit 1
    fi
fi

# ── Compose command detection (user's own Docker — no VM) ───────────────────
compose_cmd() {
    if docker compose version &>/dev/null 2>&1; then
        echo "docker compose"
    elif command -v docker-compose &>/dev/null; then
        echo "docker-compose"
    else
        printf "${RED}[provisa]${NC} Docker not found. Install Docker Desktop or colima, start it, and re-run.\n" >&2
        exit 1
    fi
}

# ── Observability flag ───────────────────────────────────────────────────────
OBSERVABILITY=false
RESET_VOLUMES=false
_ARGS=()
for _arg in "$@"; do
    case "$_arg" in
        --observability) OBSERVABILITY=true ;;
        --reset-volumes) RESET_VOLUMES=true ;;
        *) _ARGS+=("$_arg") ;;
    esac
done
set -- "${_ARGS[@]+"${_ARGS[@]}"}"

# Compose files: the airgap overlay replaces build: with the loaded provisa/*:local
# image tags — added whenever the app images came from a tarball (image_source=tarball)
# rather than a host build. Extensions in ~/.provisa/extensions/*/docker-compose.*.yml
# are appended automatically.
_build_compose_files() {
    local files="-f ${PROJECT_DIR}/docker-compose.core.yml -f ${PROJECT_DIR}/docker-compose.app.yml"
    if { [ "$IMAGE_SOURCE" = "tarball" ] || [ "$RUNTIME" = "bundled" ]; } && [ -f "${PROJECT_DIR}/docker-compose.airgap.yml" ]; then
        files="${files} -f ${PROJECT_DIR}/docker-compose.airgap.yml"
    fi
    if [ "$OBSERVABILITY" = "true" ] && [ -f "${PROJECT_DIR}/docker-compose.dev.yml" ]; then
        files="${files} -f ${PROJECT_DIR}/docker-compose.dev.yml"
    fi
    # bundled runtime (Linux AppImage): obs is always-on, compose file lives in PROJECT_DIR
    if [ "$RUNTIME" = "bundled" ] && [ -f "${PROJECT_DIR}/docker-compose.observability.yml" ]; then
        files="${files} -f ${PROJECT_DIR}/docker-compose.observability.yml"
    fi
    # Enumerate installed extensions (observability, demo, etc.)
    local ext_dir="${PROVISA_HOME}/extensions"
    if [ -d "$ext_dir" ]; then
        for ext_compose in "${ext_dir}"/*/docker-compose.*.yml; do
            [ -f "$ext_compose" ] && files="${files} -f ${ext_compose}"
        done
    fi
    echo "$files"
}

COMPOSE_FILES="$(_build_compose_files)"

# Lazily resolved on first docker command
_COMPOSE=""
get_compose() {
    if [ -z "$_COMPOSE" ]; then
        _COMPOSE="$(compose_cmd)"
    fi
    echo "$_COMPOSE"
}

# ── Service name mapping (hide internals) ───────────────────────────────────
brand_service_name() {
    local name="$1"
    case "$name" in
        postgres)        echo "Provisa Database" ;;
        pgbouncer)       echo "Provisa Connection Pool" ;;
        trino)           echo "Provisa Query Engine" ;;
        trino-worker)    echo "Provisa Query Worker" ;;
        provisa)         echo "Provisa API Server" ;;
        mongodb)         echo "Provisa Document Store" ;;
        minio)           echo "Provisa Object Storage" ;;
        kafka)           echo "Provisa Event Stream" ;;
        schema-registry) echo "Provisa Schema Registry" ;;
        redis)           echo "Provisa Cache" ;;
        zaychik)         echo "Provisa Flight Server" ;;
        provisa-ui)      echo "Provisa UI" ;;
        *)               echo "Provisa ${name}" ;;
    esac
}

# ── Output filter — replaces docker/trino/pg references ────────────────────
filter_output() {
    if command -v gsed &>/dev/null; then
        gsed \
            -e 's/\bpostgres\b/provisa-db/g' \
            -e 's/\bpostgresql\b/provisa-db/g' \
            -e 's/\bpgbouncer\b/provisa-pool/g' \
            -e 's/\btrino\b/provisa-query/g' \
            -e 's/trinodb\/trino/provisa-query-engine/g' \
            -e 's/\bdocker\b/provisa/g' \
            -e 's/\bDocker\b/Provisa/g'
    else
        sed \
            -e 's/postgresql/provisa-db/g' \
            -e 's/postgres/provisa-db/g' \
            -e 's/pgbouncer/provisa-pool/g' \
            -e 's/trinodb\/trino/provisa-query-engine/g' \
            -e 's/trino/provisa-query/g' \
            -e 's/Docker/Provisa/g' \
            -e 's/docker/provisa/g'
    fi
}

# ── Compose ps helper ── works with both nerdctl and docker compose ─────────
# nerdctl compose ps does not support Go template --format; use --format json.
# Emits "service\tstate\thealth" or "service\tstate\tstatus" lines.
# Usage: _compose_ps [health|status]
_compose_ps() {
    local mode="${1:-health}"
    local raw
    # shellcheck disable=SC2086
    raw="$($(get_compose) $COMPOSE_FILES ps --format json 2>/dev/null)" || raw=""
    [ -z "$raw" ] && return
    python3 - "$mode" "$raw" <<'PYEOF'
import sys, json
mode, raw = sys.argv[1], sys.argv[2]
try:
    items = json.loads(raw)
    if isinstance(items, dict): items = [items]
except json.JSONDecodeError:
    items = []
    for line in raw.splitlines():
        line = line.strip()
        if line:
            try: items.append(json.loads(line))
            except: pass
for c in items:
    svc = c.get('Service') or c.get('service') or ''
    raw_state  = c.get('State')  or c.get('state')  or ''
    raw_status = c.get('Status') or c.get('status') or ''
    if not raw_state:
        raw_state = 'running' if raw_status.startswith('Up') else ('exited' if 'Exited' in raw_status else raw_status)
    health = c.get('Health') or c.get('health') or ''
    third  = health if mode == 'health' else raw_status
    if svc:
        print(svc + '\t' + raw_state + '\t' + third)
PYEOF
}

# ── Health check helpers ────────────────────────────────────────────────────
wait_for_healthy() {
    local timeout="${1:-120}"
    local interval=3
    local elapsed=0

    info "Starting services..."

    while [ "$elapsed" -lt "$timeout" ]; do
        local all_healthy=true
        local ps_output
        ps_output="$(_compose_ps health)"

        if [ -z "$ps_output" ]; then
            all_healthy=false
        else
            while IFS=$'\t' read -r svc state health; do
                if [ "$state" != "running" ]; then
                    all_healthy=false
                    break
                fi
                # Services with health checks should report healthy
                if [ -n "$health" ] && [ "$health" != "healthy" ] && [ "$health" != "" ]; then
                    all_healthy=false
                    break
                fi
            done <<< "$ps_output"
        fi

        if [ "$all_healthy" = true ] && [ -n "$ps_output" ]; then
            return 0
        fi

        sleep "$interval"
        elapsed=$((elapsed + interval))
        printf "."
    done

    printf "\n"
    return 1
}

# ── Native runtime (no Docker) ───────────────────────────────────────────────
# The UI URL to open — with ?tour=1 when the demo was installed, so the guided
# tour auto-starts fresh on launch (App.tsx reads the query param).
ui_url() {
    local url="http://localhost:${UI_PORT}"
    [ "$DEMO" = "true" ] && url="${url}/?tour=1"
    echo "$url"
}

native_python() {
    if [ ! -x "${RUNTIME_DIR}/bin/python3" ]; then
        err "Native runtime missing at ${RUNTIME_DIR}. Re-run Provisa.app to complete setup."
        exit 1
    fi
    echo "${RUNTIME_DIR}/bin/python3"
}

native_running() {
    [ -f "$NATIVE_PID_FILE" ] || return 1
    local pids; pids="$(cat "$NATIVE_PID_FILE" 2>/dev/null)"
    [ -n "$pids" ] || return 1
    local p
    for p in $pids; do kill -0 "$p" 2>/dev/null && return 0; done
    return 1
}

# Deployment env for the native process (mirrors provisa.core.desktop_profile).
# Values never contain spaces, so array word-splitting is safe under bash 3.2.
native_env_pairs() {
    local -a e
    e=(
        "PROVISA_ENGINE=${DEPLOY_ENGINE}"
        "PROVISA_REDIS_EMBEDDED=1"
        "PLATFORM_DATABASE_URL=sqlite+aiosqlite:///${PROVISA_HOME}/native/platform.db"
        "TENANT_DATABASE_URL=sqlite+aiosqlite:///${PROVISA_HOME}/native/tenant.db"
        # Remote MCP on by default for the native/desktop tier (REQ-1101): a ready same-machine
        # Claude Desktop connector, loopback-only (127.0.0.1) so the always-on server stays off the
        # LAN. Role pinned explicitly (native auth:none = one local admin user), all overridable.
        "PROVISA_MCP_PORT=${PROVISA_MCP_PORT:-8009}"
        "PROVISA_MCP_HOST=${PROVISA_MCP_HOST:-127.0.0.1}"
        "PROVISA_MCP_ROLE=${PROVISA_MCP_ROLE:-admin}"
        # MCP stays plain HTTP: Claude Desktop reaches a LOCAL server only via the stdio bridge
        # (mcp-proxy), which works over http. Its custom-connector URL path is brokered from
        # Anthropic (needs a public HTTPS endpoint), so TLS buys nothing locally. TLS stays opt-in
        # (PROVISA_MCP_TLS=1) for a publicly-exposed deployment (REQ-1106).
        # Bundled runtime python (host-accessible, ships mcp-proxy) Claude Desktop launches as the
        # Node-free stdio bridge (REQ-1104). Native tier only; gates the Explore/MCP connector panel.
        "PROVISA_MCP_BRIDGE_COMMAND=$(native_python)"
    )
    [ -n "$ENGINE_URL" ]      && e+=("PROVISA_ENGINE_URL=${ENGINE_URL}")
    [ -n "$MATERIALIZE_URL" ] && e+=("PROVISA_MATERIALIZE_URL=${MATERIALIZE_URL}")
    [ -n "$TRINO_HOST" ]      && e+=("TRINO_HOST=${TRINO_HOST}")
    [ -n "$TRINO_PORT" ]      && e+=("TRINO_PORT=${TRINO_PORT}")
    [ -n "$OTLP_ENDPOINT" ]   && e+=("OTEL_EXPORTER_OTLP_ENDPOINT=${OTLP_ENDPOINT}")
    if [ "$DEMO" = "true" ]; then
        # Demo tier: point the runtime at the bundled native demo config (engine: duckdb,
        # auth: none -> no setup wizard) and mark the run a demo so the UI auto-starts the
        # guided tour (setup_router._is_demo reads PROVISA_DEMO). Resolve the config + sample-data
        # dir from the venv's own package so wheel-staged (provisa/_config) and source-checkout
        # layouts both work. Mirrors the Windows native launcher (packaging/windows/provisa-native.ps1).
        # Without this the app boots the plain installer config (no auth) and renders the first-run
        # SetupPage instead of the demo — REQ-414/REQ-972.
        local py demo_cfg demo_dir
        py="$(native_python)"
        demo_cfg="$("$py" -c 'from provisa.cli import _resolve_demo as r; print(r()[0])')"
        demo_dir="$("$py" -c 'from provisa.cli import _resolve_demo as r; print(r()[1])')"
        e+=("PROVISA_CONFIG=${demo_cfg}")
        e+=("PROVISA_DEMO_DIR=${demo_dir}")
        e+=("PROVISA_DEMO=1")
    fi
    printf '%s\n' "${e[@]}"
}

cmd_start_native() {
    printf "${CYAN}${BOLD}Starting Provisa (native — no Docker)...${NC}\n"
    mkdir -p "$LOG_DIR" "${PROVISA_HOME}/native"
    if native_running; then
        info "Provisa is already running."
        return 0
    fi
    local py; py="$(native_python)"
    local -a env_pairs; env_pairs=()
    local line
    while IFS= read -r line; do env_pairs+=("$line"); done < <(native_env_pairs)

    # Two processes: the API app (packaged factory) and the UI server, which
    # proxies API calls to PROVISA_API_URL and serves the built static UI.
    nohup env "${env_pairs[@]}" \
        "$py" -m uvicorn provisa.api.app:create_app --factory --host 0.0.0.0 --port "$API_PORT" \
        >> "${LOG_DIR}/native-api.log" 2>&1 &
    local api_pid=$!
    nohup env "${env_pairs[@]}" PROVISA_API_URL="http://localhost:${API_PORT}" \
        "$py" -m uvicorn provisa.ui_server:app --host 0.0.0.0 --port "$UI_PORT" \
        >> "${LOG_DIR}/native-ui.log" 2>&1 &
    local ui_pid=$!
    printf '%s %s\n' "$api_pid" "$ui_pid" > "$NATIVE_PID_FILE"

    printf "${GREEN}${BOLD}Provisa is running.${NC}\n"
    printf "  UI:  ${BOLD}%s${NC}\n" "$(ui_url)"
    printf "  API: ${BOLD}http://localhost:%s${NC}\n" "$API_PORT"
    [ "$AUTO_OPEN" = "true" ] && printf "\nRun ${BOLD}provisa open${NC} to open the UI.\n"
}

cmd_stop_native() {
    printf "${CYAN}${BOLD}Stopping Provisa...${NC}\n"
    if [ -f "$NATIVE_PID_FILE" ]; then
        local p
        for p in $(cat "$NATIVE_PID_FILE" 2>/dev/null); do kill "$p" 2>/dev/null || true; done
        rm -f "$NATIVE_PID_FILE"
    fi
    printf "${GREEN}${BOLD}Provisa has been shut down.${NC}\n"
}

cmd_status_native() {
    if native_running; then
        printf "${GREEN}Provisa (native) is running.${NC}\n"
        printf "  UI:  %s\n" "$(ui_url)"
    else
        printf "${DIM}Provisa (native) is not running.${NC}\n"
    fi
}

# ── Commands ────────────────────────────────────────────────────────────────
cmd_start() {
    printf "${CYAN}${BOLD}Starting Provisa...${NC}\n"
    mkdir -p "$LOG_DIR"

    local scale_arg=""
    if [ "${FED_WORKERS:-0}" -gt 0 ] 2>/dev/null; then
        scale_arg="--scale trino-worker=${FED_WORKERS}"
        info "Starting ${FED_WORKERS} query worker(s)..."
    fi

    local obs_ext="${PROVISA_HOME}/extensions/observability/docker-compose.observability.yml"
    if [ "$OBSERVABILITY" = "true" ] || [ -f "$obs_ext" ]; then
        export OTEL_EXPORTER_OTLP_ENDPOINT="${OTEL_EXPORTER_OTLP_ENDPOINT:-http://otel-collector:4317}"
        export OTEL_SERVICE_NAME="${OTEL_SERVICE_NAME:-provisa}"
    fi

    if [ "$RESET_VOLUMES" = "true" ]; then
        printf "Resetting volumes for crash recovery...\n"
        # shellcheck disable=SC2086
        $(get_compose) $COMPOSE_FILES down -v >/dev/null 2>&1 || true
    fi

    # shellcheck disable=SC2086
    $(get_compose) $COMPOSE_FILES up -d $scale_arg >/dev/null 2>&1 || true

    if wait_for_healthy 120; then
        printf "\n${GREEN}${BOLD}Provisa is running.${NC}\n"
        printf "═══════════════════════════════════════════\n"
        cmd_status
        printf "═══════════════════════════════════════════\n"
        if [ "$AUTO_OPEN" = "true" ]; then
            printf "\nRun ${BOLD}provisa open${NC} to open the UI.\n"
        fi
        if [ "$OBSERVABILITY" = "true" ] || [ -f "${PROVISA_HOME}/extensions/observability/docker-compose.observability.yml" ]; then
            printf "Grafana: ${BOLD}http://localhost:3100${NC}\n"
        fi
    else
        warn "Some services may still be starting."
        printf "Run ${BOLD}provisa status${NC} to check service health.\n"
    fi
}

cmd_stop() {
    printf "${CYAN}${BOLD}Stopping Provisa...${NC}\n"
    # shellcheck disable=SC2086
    $(get_compose) $COMPOSE_FILES down >/dev/null 2>&1 || true
    printf "${GREEN}${BOLD}Provisa has been shut down cleanly.${NC}\n"
}

cmd_restart() {
    cmd_stop
    printf "\n"
    cmd_start
}

cmd_status() {
    printf "${BOLD}Provisa Service Status${NC}\n"
    printf "═══════════════════════════════════════════\n"

    local ps_output
    ps_output="$(_compose_ps status)"

    if [ -z "$ps_output" ]; then
        printf "${DIM}No services running.${NC}\n"
        return
    fi

    printf "%-30s %-12s %s\n" "SERVICE" "STATE" "HEALTH"
    printf "%-30s %-12s %s\n" "───────" "─────" "──────"

    while IFS=$'\t' read -r svc state status; do
        local label
        label="$(brand_service_name "$svc")"
        local color="$NC"
        case "$state" in
            running) color="$GREEN" ;;
            exited|dead) color="$RED" ;;
            *) color="$YELLOW" ;;
        esac
        printf "${color}%-30s${NC} %-12s %s\n" "$label" "$state" "$status"
    done <<< "$ps_output"
}

cmd_open() {
    local url; url="$(ui_url)"
    printf "Opening Provisa at ${BOLD}${url}${NC}\n"
    case "$(uname -s)" in
        Darwin)  open "$url" ;;
        Linux)   xdg-open "$url" 2>/dev/null || printf "Open ${url} in your browser.\n" ;;
        MINGW*|MSYS*|CYGWIN*) start "$url" 2>/dev/null || printf "Open ${url} in your browser.\n" ;;
        *)       printf "Open ${url} in your browser.\n" ;;
    esac
}

cmd_logs() {
    local service="${1:-}"
    if [ -n "$service" ]; then
        local branded
        branded="$(brand_service_name "$service")"
        info "Tailing logs for ${branded}..."
        # shellcheck disable=SC2086
        $(get_compose) $COMPOSE_FILES logs -f --tail=100 "$service" 2>&1 | filter_output
    else
        # Check for local log files first
        if [ -d "$LOG_DIR" ] && ls "$LOG_DIR"/*.log &>/dev/null 2>&1; then
            info "Tailing Provisa logs from ${LOG_DIR}..."
            tail -f "$LOG_DIR"/*.log 2>/dev/null | filter_output
        else
            info "Tailing all Provisa service logs..."
            # shellcheck disable=SC2086
            $(get_compose) $COMPOSE_FILES logs -f --tail=100 2>&1 | filter_output
        fi
    fi
}

cmd_upgrade() {
    info "Checking for Provisa updates..."

    if [ -d "${PROJECT_DIR}/.git" ]; then
        local current_sha
        current_sha="$(git -C "$PROJECT_DIR" rev-parse --short HEAD 2>/dev/null || echo "unknown")"
        info "Current version: ${current_sha}"

        git -C "$PROJECT_DIR" pull --rebase 2>&1 | filter_output
        local new_sha
        new_sha="$(git -C "$PROJECT_DIR" rev-parse --short HEAD 2>/dev/null || echo "unknown")"

        if [ "$current_sha" = "$new_sha" ]; then
            ok "Already up to date."
        else
            ok "Updated: ${current_sha} -> ${new_sha}"
            info "Restarting services with new version..."
            cmd_restart
        fi
    else
        err "Provisa was not installed via git."
        err "Re-run install.sh to get the latest version."
        exit 1
    fi
}

cmd_uninstall() {
    printf "${YELLOW}${BOLD}Uninstalling Provisa...${NC}\n\n"
    printf "This will remove:\n"
    printf "  - ${PROVISA_HOME}/ (config and data)\n"
    printf "  - /usr/local/bin/provisa (CLI)\n\n"

    read -rp "Continue? [y/N] " confirm
    case "$confirm" in
        [yY]|[yY][eE][sS])
            # Stop services first if running
            info "Stopping services..."
            # shellcheck disable=SC2086
            $(get_compose) $COMPOSE_FILES down >/dev/null 2>&1 || true

            info "Removing ${PROVISA_HOME}..."
            rm -rf "$PROVISA_HOME"

            info "Removing CLI..."
            if [ -w /usr/local/bin ]; then
                rm -f /usr/local/bin/provisa
            else
                sudo rm -f /usr/local/bin/provisa
            fi
            printf "${GREEN}${BOLD}Provisa has been uninstalled.${NC}\n"
            ;;
        *)
            printf "Cancelled.\n"
            ;;
    esac
}

cmd_export() {
    local dest="${1:-}"
    local url="http://localhost:${API_PORT}/admin/config"
    local http_code body

    body="$(curl -s -w '\n__HTTP_CODE__%{http_code}' "$url" 2>/dev/null)" || {
        err "Could not reach Provisa API at ${url}. Is Provisa running?"
        exit 1
    }
    http_code="${body##*__HTTP_CODE__}"
    body="${body%$'\n'__HTTP_CODE__*}"

    if [ "$http_code" != "200" ]; then
        err "API returned HTTP ${http_code}. Is Provisa running?"
        exit 1
    fi

    if [ -n "$dest" ]; then
        printf '%s\n' "$body" > "$dest"
        ok "Config exported to ${dest}"
    else
        printf '%s\n' "$body"
    fi
}

cmd_import() {
    local src="${1:-}"
    if [ -z "$src" ]; then
        err "Usage: provisa import <file.yaml>"
        exit 1
    fi
    if [ ! -f "$src" ]; then
        err "File not found: ${src}"
        exit 1
    fi

    local url="http://localhost:${API_PORT}/admin/config"
    local http_code response

    response="$(curl -s -w '\n__HTTP_CODE__%{http_code}' \
        -X PUT "$url" \
        -H "Content-Type: application/x-yaml" \
        --data-binary "@${src}" 2>/dev/null)" || {
        err "Could not reach Provisa API at ${url}. Is Provisa running?"
        exit 1
    }
    http_code="${response##*__HTTP_CODE__}"
    response="${response%$'\n'__HTTP_CODE__*}"

    if [ "$http_code" = "200" ]; then
        ok "Config imported and reloaded from ${src}"
    else
        err "Import failed (HTTP ${http_code}): ${response}"
        exit 1
    fi
}

cmd_help() {
    printf "\n${BOLD}Provisa${NC} — Self-service data provisioning\n\n"
    printf "Usage: ${BOLD}provisa${NC} <command>\n\n"
    printf "Commands:\n"
    printf "  ${BOLD}start${NC}       Start all Provisa services\n"
    printf "    ${DIM}--observability${NC}  Also start Grafana, Prometheus, Tempo, OTel collector\n"
    printf "  ${BOLD}stop${NC}        Stop all Provisa services\n"
    printf "  ${BOLD}restart${NC}     Restart all Provisa services\n"
    printf "  ${BOLD}status${NC}      Show service status and health\n"
    printf "  ${BOLD}open${NC}        Open Provisa UI in browser\n"
    printf "  ${BOLD}logs${NC}        Tail Provisa log output\n"
    printf "  ${BOLD}export${NC}      Export config to YAML (stdout or file)\n"
    printf "    ${DIM}provisa export [file.yaml]${NC}\n"
    printf "  ${BOLD}import${NC}      Import and apply a YAML config file\n"
    printf "    ${DIM}provisa import <file.yaml>${NC}\n"
    printf "  ${BOLD}upgrade${NC}     Pull latest version and restart\n"
    printf "  ${BOLD}uninstall${NC}   Remove Provisa CLI and data\n"
    printf "  ${BOLD}help${NC}        Show this help message\n\n"
    printf "Config: ${DIM}${CONFIG_FILE}${NC}\n"
    printf "Data:   ${DIM}${PROVISA_HOME}/${NC}\n"
    printf "Logs:   ${DIM}${LOG_DIR}/${NC}\n\n"
}

# ── Dispatch ────────────────────────────────────────────────────────────────
case "${1:-help}" in
    start)      if [ "$RUNTIME" = "native" ]; then cmd_start_native; else cmd_start; fi ;;
    stop)       if [ "$RUNTIME" = "native" ]; then cmd_stop_native;  else cmd_stop;  fi ;;
    restart)    if [ "$RUNTIME" = "native" ]; then cmd_stop_native; printf "\n"; cmd_start_native; else cmd_restart; fi ;;
    status)     if [ "$RUNTIME" = "native" ]; then cmd_status_native; else cmd_status; fi ;;
    open)       cmd_open ;;
    logs)       shift; cmd_logs "${1:-}" ;;
    export)     shift; cmd_export "${1:-}" ;;
    import)     shift; cmd_import "${1:-}" ;;
    upgrade)    cmd_upgrade ;;
    uninstall)  cmd_uninstall ;;
    help|--help|-h)  cmd_help ;;
    *)
        printf "${RED}Unknown command:${NC} %s\n" "$1" >&2
        cmd_help
        exit 1
        ;;
esac
