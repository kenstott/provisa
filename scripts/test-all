#!/usr/bin/env bash
# Run the entire test suite across its process-isolation lanes and report a
# single combined coverage number.
#
# Why lanes: the e2e tier provisions its OWN isolated Docker stack on ephemeral
# ports and, running the app in-process, overrides PG_PORT/TRINO_PORT/etc. in the
# environment. The integration tier targets the shared dev stack via those same
# vars. Co-running them in one pytest process points integration at the wrong
# stack, so each lane is its own process; `coverage combine` merges the results.
#
# Lanes:
#   default   integration + unit + bdd  (shared dev stack; --ignore=tests/e2e)
#   e2e       tests/e2e                  (own isolated stack, ephemeral ports)
#   cluster   opt-in: TEST_ALL_CLUSTER=1 (helm/minikube against a live cluster)
#   packaging opt-in: TEST_ALL_PACKAGING=1 (installer/packaging flow)
#
# Usage: scripts/test-all [extra pytest args...]
set -euo pipefail
cd "$(dirname "$0")/.."

# Load .env so credential-gated lanes (Snowflake/Databricks/BigQuery/Fabric/Synapse/…) see their
# warehouse creds instead of skipping. `set -a` exports every var the file defines; skip cleanly
# when absent. Pre-set environment wins — we don't clobber vars already exported by the caller.
if [[ -f .env ]]; then
  set -a
  # shellcheck disable=SC1091
  while IFS= read -r _line || [[ -n "$_line" ]]; do
    [[ "$_line" =~ ^[[:space:]]*# ]] && continue
    [[ "$_line" =~ ^[[:space:]]*$ ]] && continue
    _key="${_line%%=*}"
    [[ -n "${!_key:-}" ]] && continue  # caller-provided value wins
    eval "export $_line"
  done < .env
  set +a
fi

COV_ARGS=(--cov=provisa --cov-report= -p no:cacheprovider)
rm -f .coverage .coverage.*

# A lane's test failures must NOT abort the script (set -e) — every lane still needs to
# run and the final `coverage combine` must always execute. Each pytest records its
# non-zero exit into `rc`; the script exits non-zero at the end if any lane failed.
rc=0

# pytest-cov auto-combines each run's parallel data into its COVERAGE_FILE at session
# end, so co-writing every lane to the default `.coverage` makes each lane clobber the
# last (and the final `coverage combine` finds no `.coverage.*` to merge — "No data to
# combine"). Give each lane its OWN data file (`.coverage.<lane>`); the final combine
# then globs `.coverage.*` and merges the lanes into one report.

# The default lane is SHARDED by service group. The isolated-stack harness
# (tests/conftest.py::_DockerServiceManager) provisions EVERY marker service the
# collected tests need for the whole session at once; running the entire default lane
# in one process brings up core + kafka + debezium + neo4j + elasticsearch + fuseki +
# mongo + prometheus simultaneously, which exhausts a typical (~12 GB) Docker host and
# OOM-kills core containers mid-run — cascading connection-refused across unrelated
# modules that pass in isolation. Sharding keeps each process's live service set within
# memory. The four `-m` selectors PARTITION the default lane (each test in exactly one
# shard); a CLI `-m` overrides the ini `addopts` `-m`, so the base exclusions are folded
# back in here, while `--ignore=tests/e2e` from addopts is preserved.
_BASE="not packaging and not cluster and not isolated"
_KAFKA="requires_kafka or requires_debezium"
_DATASTORE="requires_elasticsearch or requires_sparql or requires_mongodb or requires_prometheus"

echo "== lane: default/core (unit + bdd + core-only integration) =="
COVERAGE_FILE=.coverage.default pytest tests tests/steps \
  -m "$_BASE and not ($_KAFKA or requires_neo4j or $_DATASTORE)" "${COV_ARGS[@]}" "$@" || rc=1

echo "== lane: default/kafka (kafka + debezium) =="
COVERAGE_FILE=.coverage.kafka pytest tests tests/steps \
  -m "$_BASE and ($_KAFKA)" "${COV_ARGS[@]}" "$@" || rc=1

echo "== lane: default/neo4j =="
COVERAGE_FILE=.coverage.neo4j pytest tests tests/steps \
  -m "$_BASE and requires_neo4j and not ($_KAFKA)" "${COV_ARGS[@]}" "$@" || rc=1

echo "== lane: default/datastores (elasticsearch + sparql + mongo + prometheus) =="
COVERAGE_FILE=.coverage.datastores pytest tests tests/steps \
  -m "$_BASE and ($_DATASTORE) and not ($_KAFKA or requires_neo4j)" "${COV_ARGS[@]}" "$@" || rc=1

echo "== lane: e2e (isolated stack) =="
# addopts carries --ignore=tests/e2e for the default lane; override it here so the
# e2e lane collects exactly tests/e2e (its conftest owns the isolated stack).
# Exclude cluster: test_helm_minikube is marked [e2e, cluster] and would otherwise
# block for minutes on `minikube start`/kubectl subprocess timeouts against a
# non-existent cluster. Cluster tests run only in their own lane (TEST_ALL_CLUSTER=1).
COVERAGE_FILE=.coverage.e2e pytest tests/e2e -o addopts="" -m "e2e and not cluster" "${COV_ARGS[@]}" "$@" || rc=1

echo "== lane: isolated (own process — shared-state / JVM tests) =="
# These modules share the app's module-singleton state or a non-restartable JVM,
# so co-running them with the rest corrupts state; they pass in a clean process.
# Keep --ignore=tests/e2e: importing the e2e conftest here would repoint the
# host-app port env vars at the (down) e2e stack.
COVERAGE_FILE=.coverage.isolated pytest tests --ignore=tests/e2e -o addopts="" -m isolated "${COV_ARGS[@]}" "$@" || rc=1

if [[ "${TEST_ALL_CLUSTER:-}" == "1" ]]; then
  echo "== lane: cluster (helm/minikube) =="
  COVERAGE_FILE=.coverage.cluster pytest tests/e2e/test_helm_minikube.py -o addopts="" -m cluster "${COV_ARGS[@]}" "$@" || rc=1
fi

if [[ "${TEST_ALL_PACKAGING:-}" == "1" ]]; then
  echo "== lane: packaging =="
  COVERAGE_FILE=.coverage.packaging pytest -o addopts="" -m packaging "${COV_ARGS[@]}" "$@" || rc=1
fi

echo "== combined coverage =="
coverage combine  # merges every .coverage.<lane> into .coverage
coverage report -m
coverage xml

exit $rc
