{
  "title": "Provisa Overview",
  "uid": "provisa-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(provisa_http_server_duration_milliseconds_count{job=\"otel-collector\"}[1m])",
          "legendFormat": "{{http_route}} {{http_method}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 2,
      "title": "Request Latency p50 / p95 / p99 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(provisa_http_server_duration_milliseconds_bucket{job=\"otel-collector\"}[1m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(provisa_http_server_duration_milliseconds_bucket{job=\"otel-collector\"}[1m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(provisa_http_server_duration_milliseconds_bucket{job=\"otel-collector\"}[1m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 3,
      "title": "Error Rate (5xx/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(provisa_http_server_duration_milliseconds_count{job=\"otel-collector\", http_status_code=~\"5..\"}[1m])",
          "legendFormat": "{{http_route}} 5xx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    },
    {
      "id": 4,
      "title": "Active HTTP Connections",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "provisa_http_server_active_requests{job=\"otel-collector\"}",
          "legendFormat": "active"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 100 }
          ]
        }}
      }
    },
    {
      "id": 5,
      "title": "GraphQL Query Duration p95 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(provisa_graphql_query_duration_milliseconds_bucket{job=\"otel-collector\"}[1m]))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "id": 6,
      "title": "DB Query Duration p95 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(provisa_db_client_operation_duration_milliseconds_bucket{job=\"otel-collector\"}[1m]))",
          "legendFormat": "{{db_system}} p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "id": 7,
      "title": "OTel Collector — Spans Received/s",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(otelcol_receiver_accepted_spans{job=\"otel-collector\"}[1m])",
          "legendFormat": "accepted"
        },
        {
          "expr": "rate(otelcol_receiver_refused_spans{job=\"otel-collector\"}[1m])",
          "legendFormat": "refused"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    }
  ]
}
