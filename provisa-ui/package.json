{
  "name": "provisa-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.9.0"
  },
  "scripts": {
    "copy-docs": "node scripts/copy-docs.mjs",
    "predev": "node scripts/copy-docs.mjs",
    "dev": "vite",
    "generate-schema": "tsx scripts/generate-schema.ts",
    "screenshots": "npx tsx scripts/capture-screenshots.ts",
    "prebuild": "node scripts/copy-docs.mjs",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "preview": "vite preview",
    "test:unit": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "coverage:clean": "rm -rf .nyc_output .nyc_output_flat coverage",
    "coverage:merge": "mkdir -p .nyc_output_flat && cp .nyc_output/vitest/coverage-final.json .nyc_output_flat/vitest.json && cp .nyc_output/playwright/*.json .nyc_output_flat/ && nyc merge .nyc_output_flat coverage/merged.json",
    "coverage:report": "mkdir -p coverage/.nyc_output && cp coverage/merged.json coverage/.nyc_output/coverage-final.json && nyc report --temp-dir coverage/.nyc_output --reporter text --reporter html --report-dir coverage/html",
    "coverage": "npm run coverage:clean && npm run test:unit && npm run test:e2e && npm run coverage:merge && npm run coverage:report"
  },
  "dependencies": {
    "@apollo/client": "^4.2.2",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@graphiql/plugin-explorer": "^5.1.2",
    "@graphiql/toolkit": "^0.12.0",
    "@mui/material": "^9.0.1",
    "@neo4j-cypher/codemirror": "^1.0.3",
    "@uiw/react-codemirror": "^4.25.10",
    "cm6-graphql": "^0.2.1",
    "cytoscape": "^3.33.4",
    "cytoscape-elk": "^2.3.0",
    "cytoscape-fcose": "^2.2.0",
    "cytoscape-layout-utilities": "^1.1.1",
    "cytoscape-svg": "^0.4.0",
    "driver.js": "^1.6.0",
    "esbuild": "^0.28.0",
    "firebase": "^12.14.0",
    "graphiql": "^5.2.3",
    "graphql": "^16.14.0",
    "graphql-voyager": "^2.1.0",
    "idb-keyval": "^6.2.4",
    "lucide-react": "^1.17.0",
    "mermaid": "^11.15.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.16.0",
    "remark-gfm": "^4.0.1",
    "rolldown": "^1.0.3",
    "sql-formatter": "^15.8.0",
    "vite-plugin-monaco-editor": "^1.1.0"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^7.1.2",
    "@graphql-codegen/client-preset": "^6.0.1",
    "@graphql-tools/graphql-file-loader": "^8.1.14",
    "@playwright/test": "^1.60.0",
    "@rollup/plugin-graphql": "^3.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "nyc": "^18.0.0",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.16",
    "vite-plugin-istanbul": "^9.0.1",
    "vitest": "^4.1.8"
  }
}
