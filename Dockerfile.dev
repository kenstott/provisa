# syntax=docker/dockerfile:1
# Dev/test image — installs from PyPI (no pre-built wheels required)
FROM python:3.12-slim
WORKDIR /app
COPY pyproject.toml .
RUN pip install --no-cache-dir .
COPY main.py pyproject.toml ./
COPY provisa/ ./provisa/
COPY static/ ./static/
RUN mkdir -p ./config && useradd -m -u 1000 appuser && chown -R appuser /app
USER 1000

EXPOSE 8000 3000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
